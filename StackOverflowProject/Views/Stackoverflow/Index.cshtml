@model StackOverflowProject.Controllers.StackoverflowController.ViewModel
@using System.Net
@using System.Text.RegularExpressions

@functions {
    public static string BuildPreview(string htmlBody, int maxLength = 220)
    {
        if (string.IsNullOrWhiteSpace(htmlBody))
        {
            return string.Empty;
        }

        var withoutTags = Regex.Replace(htmlBody, "<.*?>", " ");
        var decoded = WebUtility.HtmlDecode(withoutTags);
        var normalized = Regex.Replace(decoded, "\\s+", " ").Trim();

        if (normalized.Length <= maxLength)
        {
            return normalized;
        }

        return normalized[..maxLength].TrimEnd() + "...";
    }
}

<script>
    var page = {};

    page.init = function () {
        $(window).scrollTop(0);

        $('input[type="radio"]').on('change', function () {
            var $radio = $(this);
            var $formCheck = $radio.closest('.form-check');
            var $questionBlock = $radio.closest('[data-question-answers]');
            var $result = $formCheck.find('.answer-result');
            var isAccepted = $radio.attr('data-is-accepted') === 'true';

            $questionBlock.find('.answer-result')
                .text('')
                .removeClass('text-success text-danger');

            if (isAccepted) {
                $result.text('Correct!').addClass('text-success');
            } else {
                $result.text('Wrong answer').addClass('text-danger');
            }
        });
    };

    page.toggleArrow = function (id) {
        var card = document.getElementById(id);
        var button = card.querySelector('.btn');
        var arrowIcon = card.querySelector('.arrow-icon i');
        var isCollapsed = button.getAttribute('aria-expanded') === 'true';

        document.querySelectorAll('.arrow-icon i').forEach(function (icon) {
            icon.classList.remove('fa-chevron-up');
            icon.classList.add('fa-chevron-down');
        });

        if (isCollapsed) {
            arrowIcon.classList.remove('fa-chevron-up');
            arrowIcon.classList.add('fa-chevron-down');
        } else {
            arrowIcon.classList.remove('fa-chevron-down');
            arrowIcon.classList.add('fa-chevron-up');
        }
    };

    $(function () {
        page.init();
    });
</script>

<h2 class="text-primary">StackOverflow Questions</h2>
<h6>Choose the right answer to the question</h6>

<div class="accordion" id="questionsAccordion">
    @for (int i = 0; i < Model.Questions.Count; i++)
    {
        var question = Model.Questions[i];
        var cardId = $"questionCard_{question.QuestionID}";
        var collapseId = $"collapse_{question.QuestionID}";

        <div class="card mb-3" id="@cardId">
            <div class="card-header p-0">
                <button class="btn w-100 text-start d-flex justify-content-between align-items-center p-3"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#@collapseId"
                        aria-expanded="false"
                        aria-controls="@collapseId"
                        onclick="page.toggleArrow('@cardId')">

                    <div>
                        <div class="fw-semibold">@question.Title</div>
                        <div class="text-muted small">@question.Answers.Count answers </div>
                    </div>

                    <span class="arrow-icon ms-3">
                        <i class="fa-solid fa-chevron-down"></i>
                    </span>
                </button>
            </div>

            <div id="@collapseId" class="collapse" data-bs-parent="#questionsAccordion">
                <div class="card-body p-0" data-question-answers="@question.QuestionID">
                    @foreach (var answer in question.Answers)
                    {
                        <div class="border-top ps-4 py-3">
                            <div class="form-check mb-0">
                                <input class="form-check-input"
                                       type="radio"
                                       name="guess_question_@question.QuestionID"
                                       value="@answer.AnswerID"
                                       data-is-accepted="@(answer.AnswerID == question.AcceptedAnswerID ? "true" : "false")"
                                       id="answer_@answer.AnswerID" />

                                <label class="form-check-label small w-100" for="answer_@answer.AnswerID">
                                    @BuildPreview(answer.Body, 220)
                                </label>

                                <span class="answer-result d-block mt-2 small"></span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>